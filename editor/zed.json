// Zed settings
{
  "cli_default_open_behavior": "existing_window",
  "icon_theme": "Material Icon Theme",
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "dontAsk",
        "effort": "default",
        "model": "haiku"
      },
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Fadetouched Blur"
  },
  "buffer_font_family": "DepartureMono Nerd Font Mono",
  "ui_font_family": "DepartureMono Nerd Font Mono",
  "markdown_preview_font_family": "DepartureMono Nerd Font Mono",
  "markdown_preview_code_font_family": "DepartureMono Nerd Font Mono",
  "terminal": {
    "shell": {
      "program": "powershell.exe"
    }
  }
}
